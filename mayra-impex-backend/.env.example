# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
# Key ring format: kid1:secret1,kid2:secret2 (recommended in production)
JWT_ACCESS_KEYS=
JWT_ACCESS_ACTIVE_KID=
JWT_REFRESH_KEYS=
JWT_REFRESH_ACTIVE_KID=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Auth security
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
FAILED_LOGIN_DELAY_MS=700

# Replay attack protection
REPLAY_WINDOW_MS=120000
NONCE_TTL_MS=300000

# Redis (required in production for distributed replay protection)
REDIS_URL=redis://localhost:6379

# Redis-backed rate limiting
API_RATE_WINDOW_MS=900000
API_RATE_LIMIT=100
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_LIMIT=10
ADMIN_WRITE_RATE_WINDOW_MS=300000
ADMIN_WRITE_RATE_LIMIT=120

# SIEM / Monitoring
SECURITY_SERVICE_NAME=mayra-impex-backend
SECURITY_SIEM_WEBHOOK_URL=
SECURITY_SIEM_WEBHOOK_TOKEN=
ELK_LOG_INGEST_URL=
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
SENTRY_DSN=
SIEM_HTTP_TIMEOUT_MS=4000

# Alert thresholds
ALERT_BRUTE_FORCE_WINDOW_MS=300000
ALERT_BRUTE_FORCE_THRESHOLD=8
ALERT_OTP_ABUSE_WINDOW_MS=600000
ALERT_OTP_ABUSE_THRESHOLD=5
ALERT_REPLAY_WINDOW_MS=600000
ALERT_REPLAY_THRESHOLD=2
ALERT_ADMIN_ANOMALY_WINDOW_MS=3600000
ALERT_ADMIN_ANOMALY_THRESHOLD=2
ADMIN_IP_HISTORY_TTL_SECONDS=7776000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Prisma / Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/mayra_impex

# Cloudinary
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

SMTP_USER=your_gmail_address@gmail.com
ORDER_NOTIFICATION_EMAIL=recipient@example.com

# Twilio WhatsApp Configuration
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
ADMIN_WHATSAPP_NUMBER=whatsapp:+919876543210
ORDER_NOTIFICATION_WHATSAPP=whatsapp:+917276193438

# CORS allow list (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:19000,http://localhost:8081
